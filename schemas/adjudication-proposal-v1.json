{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adjudication Proposal v1",
  "type": "object",
  "required": [
    "proposal_id",
    "created_at",
    "from_lane",
    "target_lane",
    "contradiction_id",
    "contradiction_kind",
    "sources",
    "evidence_bundle",
    "authority_weights",
    "proposed_decision",
    "confidence",
    "mutation_required",
    "human_required",
    "ratification_required"
  ],
  "properties": {
    "proposal_id": {
      "type": "string",
      "format": "uuid"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "from_lane": {
      "type": "string",
      "enum": [
        "library",
        "archivist",
        "swarmmind",
        "kernel"
      ]
    },
    "target_lane": {
      "type": "string",
      "enum": [
        "library",
        "archivist",
        "swarmmind",
        "kernel",
        "all"
      ]
    },
    "contradiction_id": {
      "type": "string"
    },
    "contradiction_kind": {
      "type": "string",
      "enum": [
        "stale_state",
        "temporal_desync",
        "schema_behavior_mismatch",
        "authority_conflict",
        "source_obsolescence",
        "duplicate_or_tag_cluster",
        "true_semantic_conflict",
        "unknown"
      ]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_bundle": {
      "type": "object",
      "required": [
        "evidence_paths"
      ],
      "properties": {
        "evidence_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "authority_weights": {
      "type": "object"
    },
    "proposed_decision": {
      "type": "string",
      "enum": [
        "mark_spurious_candidate",
        "preserve_both",
        "needs_lane_review",
        "needs_archivist_ratification",
        "quarantine",
        "needs_human",
        "no_action"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "mutation_required": {
      "type": "boolean"
    },
    "human_required": {
      "type": "boolean"
    },
    "ratification_required": {
      "type": "boolean"
    },
    "rollback_plan": {
      "type": "object"
    },
    "forbidden_auto_apply": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}