{
  "$id": "https://example.com/schemas/inbox-message-v1.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
"title": "Inbox Message Schema v1.5",
"description": "Cross-lane inbox message format. v1.5: vote/vote-tally in task_kind enum for convergence voting. v1.4: uncertainty packet, review round protocol, prior_attempts. v1.3: idempotency_key relaxed to any non-empty string, task_kind optional for alert/ack/heartbeat. v1.2: signature/key_id REQUIRED, ack+alert in type enum. v1.1: payload.compression, execution.parent_id, watcher block, canonical_paths, delivery_verification.",
  "type": "object",
  "properties": {
 "schema_version": {
  "type": "string",
  "default": "1.3",
  "enum": [
  "1.0",
  "1.1",
  "1.2",
  "1.3",
  "1.4",
  "1.5"
  ]
 },
    "task_id": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1,
      "description": "v1.3: Relaxed from hex64 to any non-empty string. Lanes generate descriptive keys."
    },
    "from": {
      "type": "string",
      "default": "library"
    },
  "to": {
    "type": "string",
    "enum": [
      "archivist",
      "library",
      "swarmmind",
      "kernel",
      "broadcast",
      "all"
    ]
  },
  "type": {
    "type": "string",
    "enum": [
      "task",
      "response",
      "heartbeat",
      "escalation",
      "handoff",
      "ack",
      "alert",
      "notification",
      "status"
    ]
  },
 "task_kind": {
  "type": "string",
  "enum": [
  "proposal",
  "review",
  "amendment",
  "ratification",
  "vote",
  "vote-tally",
  "ack",
  "done",
  "status",
  "report",
  "handoff",
  "alert",
  "notification",
  "heartbeat",
  "audit"
  ],
  "description": "v1.5: Added vote, vote-tally for convergence voting. v1.3: Optional for alert/ack/heartbeat types. Required for task/response/escalation/handoff."
 },
    "priority": {
      "type": "string",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "subject": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "requires_action": {
      "type": "boolean"
    },
    "payload": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "inline",
            "path",
            "chunked"
          ]
        },
        "compression": {
          "type": "string",
          "enum": [
            "none",
            "gzip"
          ],
          "default": "none",
          "description": "v1.1: Compression for large payloads. gzip recommended for body > 2000 chars."
        },
        "path": {
          "type": "string"
        },
        "chunk": {
          "type": "object",
          "properties": {
            "index": {
              "type": "integer"
            },
            "count": {
              "type": "integer"
            },
            "group_id": {
              "type": "string"
            }
          },
          "required": [
            "index",
            "count"
          ]
        }
      },
      "required": [
        "mode"
      ]
    },
    "execution": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "manual",
            "session_task",
            "watcher"
          ]
        },
        "engine": {
          "type": "string",
          "enum": [
            "kilo",
            "opencode",
            "other"
          ]
        },
        "actor": {
          "type": "string",
          "enum": [
            "lane",
            "subagent",
            "watcher"
          ],
          "description": "v1.1: 'watcher' added for watcher-initiated processing provenance."
        },
        "session_id": {
          "type": "string"
        },
        "parent_id": {
          "type": "string",
          "default": null,
          "description": "v1.1: Links to parent task for fan-out/fan-in patterns. Null if this is a root task."
        }
      },
      "required": [
        "mode",
        "engine",
        "actor"
      ]
    },
    "lease": {
      "type": "object",
      "properties": {
        "owner": {
          "type": "string"
        },
        "acquired_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time"
        },
        "renew_count": {
          "type": "integer",
          "default": 0
        },
        "max_renewals": {
          "type": "integer",
          "default": 3
        }
      }
    },
    "retry": {
      "type": "object",
      "properties": {
        "attempt": {
          "type": "integer",
          "default": 1
        },
        "max_attempts": {
          "type": "integer",
          "default": 3
        },
        "last_error": {
          "type": "string"
        },
        "last_attempt_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evidence": {
      "type": "object",
      "properties": {
        "required": {
          "type": "boolean",
          "default": true
        },
        "evidence_path": {
          "type": "string"
        },
        "verified": {
          "type": "boolean",
          "default": false
        },
        "verified_by": {
          "type": "string"
        },
        "verified_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evidence_exchange": {
      "type": "object",
      "description": "v1.3: Convergence evidence exchange block. Required when evidence.required is true for response/ack types.",
      "properties": {
        "artifact_path": {
          "type": "string"
        },
        "artifact_type": {
          "type": "string",
    "enum": [
      "benchmark",
      "profile",
      "release",
      "log",
      "response",
      "report",
      "artifact"
    ]
        },
        "delivered_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "artifact_path",
        "artifact_type",
        "delivered_at"
      ]
    },
    "heartbeat": {
      "type": "object",
      "properties": {
        "interval_seconds": {
          "type": "integer",
          "default": 300
        },
        "last_heartbeat_at": {
          "type": "string",
          "format": "date-time"
        },
        "timeout_seconds": {
          "type": "integer",
          "default": 900
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "done",
            "failed",
            "escalated",
            "timed_out"
          ]
        }
      }
    },
    "watcher": {
      "type": "object",
      "description": "v1.1: Watcher policy block for inbox consumer configuration.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "poll_seconds": {
          "type": "integer",
          "default": 60
        },
        "p0_fast_path": {
          "type": "boolean",
          "default": true
        },
        "max_concurrent": {
          "type": "integer",
          "default": 1
        },
        "heartbeat_required": {
          "type": "boolean",
          "default": true
        },
        "stale_after_seconds": {
          "type": "integer",
          "default": 300
        },
        "backoff": {
          "type": "object",
          "properties": {
            "initial_seconds": {
              "type": "integer",
              "default": 60
            },
            "max_seconds": {
              "type": "integer",
              "default": 300
            },
            "multiplier": {
              "type": "integer",
              "default": 2
            }
          }
        }
      }
    },
    "canonical_paths": {
      "type": "object",
      "description": "v1.1: Canonical delivery paths. Senders MUST write to the target lane's canonical path, NOT their own local mirror.",
      "properties": {
        "archivist": {
          "type": "string",
          "default": "S:/Archivist-Agent/lanes/archivist/inbox/"
        },
        "library": {
          "type": "string",
          "default": "S:/self-organizing-library/lanes/library/inbox/"
        },
        "swarmmind": {
          "type": "string",
          "default": "S:/SwarmMind/lanes/swarmmind/inbox/"
        },
        "kernel": {
          "type": "string",
          "default": "S:/kernel-lane/lanes/kernel/inbox/"
        }
      }
    },
    "delivery_verification": {
      "type": "object",
      "description": "v1.1: Post-write delivery verification. Sender SHOULD verify file exists at canonical path after writing.",
      "properties": {
        "verified": {
          "type": "boolean",
          "default": false
        },
        "verified_at": {
          "type": "string",
          "format": "date-time"
        },
        "retries": {
          "type": "integer",
          "default": 0
        }
      }
    },
    "signature": {
      "type": "string",
      "description": "v1.2: JWS compact signature. EdDSA (Ed25519) preferred; RS256 legacy.",
      "minLength": 1,
      "pattern": "^eyJ[A-Za-z0-9_-]+\\.eyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$"
    },
  "signature_alg": {
    "type": "string",
    "description": "v1.2: Signature algorithm. EdDSA preferred (Ed25519). RS256 legacy.",
    "enum": [
      "RS256",
      "EdDSA"
    ],
"default": "EdDSA"
      },
      "key_id": {
        "type": "string",
        "description": "v1.2: Key identifier (first 16 hex chars of SHA-256 of public key). MUST match trust store.",
        "minLength": 16,
        "maxLength": 16,
        "pattern": "^[a-f0-9]{16}$"
      },
"uncertainty": {
      "type": "object",
      "description": "v1.4: Uncertainty packet (UNCERTAINTY_PACKET_V1). Surfaces stalled/uncertain work. Recommended for all task/response/escalation types. See schemas/uncertainty-packet-v1.json.",
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "type": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["missing_evidence", "conflicting_sources", "tool_failure", "stale_state", "ambiguous_intent", "blocked_by_permission", "implementation_unknown", "runtime_not_verified", "dependency_unresolved", "partial_completion"]
          },
          "minItems": 1
        },
        "why": {
          "type": "string",
          "minLength": 1
        },
        "evidence_needed": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "operator_decision_needed": {
          "type": "boolean",
          "default": false
        },
        "next_safe_check": {
          "type": "string"
        },
        "detected_at": {
          "type": "string",
          "format": "date-time"
        },
        "detected_by": {
          "type": "string"
        }
      },
      "required": ["level", "type", "why", "evidence_needed", "operator_decision_needed", "next_safe_check"]
    },
  "review": {
    "type": "object",
    "description": "v1.4: Review round protocol (REVIEW_ROUND_PROTOCOL_V1). Iterative review loop for convergence and implementation. See schemas/review-round-protocol-v1.json.",
    "properties": {
      "round": {
        "type": "integer",
        "minimum": 1,
        "default": 1
      },
      "reviewer": {
        "type": "string"
      },
      "status": {
        "type": "string",
        "enum": ["draft", "needs_repair", "verified_partial", "verified_accept", "rejected", "escalated"]
      },
      "feedback": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "issue": { "type": "string" },
            "required_fix": { "type": "string" },
            "evidence_required": { "type": "string" }
          },
          "required": ["issue", "required_fix", "evidence_required"]
        }
      },
      "previous_rounds": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "round": { "type": "integer", "minimum": 1 },
            "result": { "type": "string", "enum": ["needs_repair", "verified_partial", "verified_accept", "rejected", "escalated"] },
            "unresolved_items": { "type": "integer", "minimum": 0 }
          },
          "required": ["round", "result", "unresolved_items"]
        }
      },
      "max_rounds": {
        "type": "integer",
        "minimum": 1,
        "default": 3
      },
      "escalation_reason": {
        "type": "string"
      }
    },
    "required": ["round", "reviewer", "status", "feedback", "max_rounds"]
  },
  "prior_attempts": {
    "type": "array",
    "description": "v1.4: Failed attempt records (PRIOR_ATTEMPTS_V1). Tells next agent what NOT to repeat. See schemas/prior-attempts-v1.json.",
    "items": {
      "type": "object",
      "properties": {
        "attempt_id": { "type": "string", "minLength": 1 },
        "actor": { "type": "string" },
        "action": { "type": "string" },
        "result": { "type": "string" },
        "failed_because": { "type": "string" },
        "do_not_repeat": { "type": "string" },
        "useful_evidence": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["attempt_id", "actor", "action", "result", "failed_because", "do_not_repeat"]
    }
  }
},
  "required": [
    "schema_version",
    "task_id",
    "idempotency_key",
    "from",
    "to",
    "type",
    "priority",
    "subject",
    "body",
    "timestamp",
    "requires_action",
    "payload",
    "execution",
    "lease",
    "retry",
    "evidence",
    "heartbeat",
    "signature",
    "key_id"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "task",
              "response",
              "escalation",
              "handoff",
              "notification",
              "status"
            ]
          }
        }
      },
      "then": {
        "required": [
          "task_kind"
        ]
      }
    }
  ]
}