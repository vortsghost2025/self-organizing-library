{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "watch": "node scripts/inbox-watcher.js --watch",
    "watch:once": "node scripts/inbox-watcher.js",
    "heartbeat": "node scripts/heartbeat.js --continuous",
    "heartbeat:check": "node scripts/heartbeat.js --check",
    "heartbeat:once": "node scripts/heartbeat.js",
    "dev": "next dev",
    "worker": "node scripts/lane-worker.js --watch --apply --poll-seconds 60",
    "worker:parallel": "powershell -File scripts/start-workers.ps1 -Count 3",
    "worker:stop": "powershell -Command \"Get-Job -Name LibraryWorker* | Stop-Job -Force; Remove-Job -Name LibraryWorker*\"",
    "sub-lane:create": "node scripts/create-sub-lane.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "identity:export": "node scripts/export-identity.js",
    "identity:import": "node scripts/import-identity.js",
    "governed-start": "node scripts/governed-start.js",
    "generate-keys": "node scripts/generate-library-keys.js",
    "test-lane-consistency": "node scripts/test-lane-consistency.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "act:daemon": "node scripts/act-daemon.js",
    "act:daemon:dry": "node scripts/act-daemon.js --dry-run",
    "act:daemon:status": "node -e \"console.log(JSON.stringify(require('fs').readFileSync('docs/autonomous-cycle-test/daemon-state.json','utf8'))||'no state')\"",
    "act:daemon:reset": "node -e \"require('fs').unlinkSync('docs/autonomous-cycle-test/daemon-state.json');console.log('state reset')\"",
    "verdict": "node scripts/generate-verdict.js",
    "provenance:verify": "node scripts/verify-output-provenance.js",
    "health": "curl -s http://localhost:3000/api/health | jq",
    "generate-index": "node scripts/generate-site-index.js",
    "postbuild": "npx pagefind --site .next/server/app --output-path public/pagefind"
  },
  "dependencies": {
    "@kilocode/app-builder-db": "github:Kilo-Org/app-builder-db#main",
    "@react-sigma/core": "^5.0.6",
    "@react-sigma/layout-forceatlas2": "^5.0.6",
    "drizzle-orm": "^0.45.2",
    "graphology": "^0.26.0",
    "graphology-generators": "^0.11.2",
    "graphology-layout": "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-shortest-path": "^2.1.0",
    "graphology-simple-path": "^0.2.0",
    "graphology-types": "^0.24.8",
    "next": "^16.1.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sigma": "^3.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.0",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
