# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Identity keys (NEVER commit)
.identity/
*.key
keys.json

# Context buffer (working notes, not source)
/context-buffer/

# Session memory (persists locally)
.memory/

# Inbox hygiene - prevent UUID/temp heartbeat files from being committed
# Only heartbeat-{lane}.json (single file per lane) should exist
lanes/*/inbox/blocked/
lanes/*/inbox/!(*-library.json|README.md)
lanes/*/inbox/processed/
lanes/*/inbox/expired/
lanes/*/broadcast/trust-store.json
lanes/*/inbox/watcher.log
lanes/*/inbox/heartbeat-*.json
!lanes/*/inbox/heartbeat-library.json
lanes/*/outbox/

lanes/*/outbox/unsigned/
logs/quarantine-tracker.json

# Pagefind generated index (rebuilt on each build)
/public/pagefind/
.vercel
nul

# Compact audit runtime artifacts
.compact-audit/
COMPACT_CONTEXT_HANDOFF.md
lanes/*/state/traces/
lanes/*/state/worker-audit.log

# WSL/Windows mount artifacts
S:/
