{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Artifact Schema",
  "description": "Schema for library artifacts in the self-organizing library system",
  "type": "object",
  "required": ["id", "title", "type", "path", "status"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the artifact"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "description": "Human-readable title of the artifact"
    },
    "type": {
      "type": "string",
      "enum": ["repo", "paper", "doc", "session"],
      "description": "Type of artifact"
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute file path or URL to the artifact"
    },
    "source": {
      "type": "string",
      "enum": ["C:", "S:", "web", "manual", "unknown"],
      "default": "unknown",
      "description": "Source location where artifact resides"
    },
    "status": {
      "type": "string",
      "enum": ["canonical", "bridge", "archive", "unknown"],
      "default": "unknown",
      "description": "Canonical status of the artifact"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 100
      },
      "default": [],
      "description": "Tags for categorization"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "modified": {
          "type": "string",
          "format": "date-time",
          "description": "Last modification timestamp"
        },
        "size": {
          "type": "number",
          "minimum": 0,
          "description": "Size in bytes"
        },
        "wordCount": {
          "type": "number",
          "minimum": 0,
          "description": "Word count if applicable"
        },
        "extension": {
          "type": "string",
          "description": "File extension"
        }
      },
      "additionalProperties": true
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "default": [],
      "description": "IDs of related artifacts"
    },
    "notes": {
      "type": "string",
      "default": "",
      "description": "Freeform user notes"
    }
  },
  "additionalProperties": false
}
