{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "openrouter/openrouter/free",
  "disabled_providers": [
    "lmstudio",
    "ollama"
  ],
  "agent": {
    "orchestrator": {
      "model": "kilo/kilo-auto/free",
      "tools": {
        "invalid": true
      },
      "permission": {
        "question": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "task": "allow",
        "webfetch": "allow",
        "todowrite": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "model": "nvidia/openai/gpt-oss-120b"
    },
    "code": {
      "model": "nvidia/z-ai/glm-5.1"
    },
    "build": {
      "model": "openrouter/openrouter/free"
    },
    "debug": {
      "model": "openrouter/openai/gpt-oss-120b:free"
    },
    "ask": {
      "model": "openrouter/openrouter/free"
    },
    "general": {
      "model": "openrouter/openrouter/free"
    },
    "code-reviewer": {
      "model": "openrouter/openrouter/free"
    }
  },
  "provider": {
    "openrouter": {
      "options": {
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "openai/gpt-4o": {
          "name": "GPT-4o",
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 4096
          }
        },
        "openai/gpt-4o-mini": {
          "name": "GPT-4o Mini",
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    },
    "z-ai": {
      "models": {
        "glm-5.1": {
          "name": "GLM-5.1",
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  },
  "permission": {
    "external_directory": {
      "S:\\self-organizing-library": "allow",
      "S:\\Archivist-Agent": "allow",
      "S:\\SwarmMind Self-Optimizing Multi-Agent AI System": "allow",
      "*": "allow"
    },
    "bash": {
      "*": "allow"
    },
    "read": {
      "*": "allow"
    },
    "write": {
      "*": "allow"
    },
    "edit": {
      "*": "allow"
    },
    "web": {
      "*": "allow"
    }
  }
}
